             `(P0, P1, P2, P3)` implements `RequiredPluginsInstalled<P, (I0, I1, I2, I3)>`
             `(P0, P1, P2, P3, P4)` implements `RequiredPluginsInstalled<P, (I0, I1, I2, I3, I4)>`
             `(P0, P1, P2, P3, P4, P5)` implements `RequiredPluginsInstalled<P, (I0, I1, I2, I3, I4, I5)>`
             `(P0, P1, P2, P3, P4, P5, P6)` implements `RequiredPluginsInstalled<P, (I0, I1, I2, I3, I4, I5, I6)>`
             `(P0, P1, P2, P3, P4, P5, P6, P7)` implements `RequiredPluginsInstalled<P, (I0, I1, I2, I3, I4, I5, I6, I7)>`
